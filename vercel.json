{
  "version": 2,
  "services": [
    {
      "name": "frontend",
      "root": "frontend",
      "framework": "vite"
    },
    {
      "name": "backend",
      "root": "backend",
      "framework": "express",
      "route": "/api"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/api/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "/backend/images/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
